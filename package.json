{
  "name": "openviking-opencode-plugins",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenViking memory plugin for OpenCode with Codex-style automatic recall, capture, compaction commit, and manual tools.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "install:local": "node scripts/install-local.mjs",
    "smoke:docker": "node --import tsx scripts/smoke-openviking-plugin.ts",
    "smoke:real": "node --import tsx scripts/smoke-openviking-plugin-real.ts"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0"
  }
}
